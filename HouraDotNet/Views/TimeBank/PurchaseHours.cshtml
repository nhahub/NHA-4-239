@model IEnumerable<FiatPackage>
@{
    ViewData["Title"] = "Buy Hours";
    int balanceMinutes = ViewBag.CurrentBalance ?? 0;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Buy Hours - Houra</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
    <style>
        body {
            margin: 0;
            font-family: Arial, sans-serif;
            background-color: #fff;
            text-align: center;
            padding: 30px;
        }

        .close-btn {
            position: fixed;
            top: 18px;
            right: 22px;
            width: 30px;
            height: 30px;
            border-radius: 50%;
            background: #f4f0eb;
            color: #a58f7c;
            border: none;
            font-size: 14px;
            display: flex;
            align-items: center;
            justify-content: center;
            cursor: pointer;
            text-decoration: none;
            box-shadow: 0 2px 8px rgba(0,0,0,0.08);
            transition: all 0.2s ease;
            z-index: 10;
        }

            .close-btn:hover {
                background: #f77930;
                color: #fff;
                transform: rotate(90deg);
            }

        .alert {
            background-color: #f77930;
            color: #000;
            padding: 15px 20px;
            border-radius: 10px;
            font-size: 26px;
            font-weight: bold;
            display: flex;
            margin: 0 auto 40px;
            align-items: center;
            max-width: 600px;
            line-height: 40px;
            gap: 20px;
        }

        .buy-title {
            font-size: 32px;
            font-weight: bold;
            margin-bottom: 10px;
        }

        .subtitle {
            color: #555;
            margin-bottom: 40px;
        }

        .plans {
            display: flex;
            justify-content: center;
            gap: 30px;
            margin-bottom: 40px;
            flex-wrap: wrap;
            font-weight: bold;
        }

        .plan {
            background-color: #f0dcb9;
            border-radius: 20px;
            padding: 20px 30px;
            width: 180px;
            box-shadow: 0 4px 10px rgba(0, 0, 0, 0.08);
            margin-top: 20px;
        }

            .plan h3 {
                font-size: 20px;
                margin: 10px 0;
            }

            .plan p {
                font-size: 18px;
                margin: 10px 0;
            }

            .plan button {
                background-color: #f77930;
                border: none;
                border-radius: 20px;
                padding: 10px 20px;
                color: #000;
                font-weight: bold;
                cursor: pointer;
                margin-top: 15px;
            }
    </style>
</head>
<body>

    <a class="close-btn" asp-controller="Dashboard" asp-action="Profile" title="Back to profile">
        <i class="fa-solid fa-xmark"></i>
    </a>

    <div class="alert">
        <div class="icon"><i class="fa-solid fa-circle-exclamation fa-lg" style="color: #f0dcb9;"></i></div>
        <div class="text">
            @if (balanceMinutes > 0)
            {
                <text>You currently have @(balanceMinutes / 60)h @(balanceMinutes % 60)m remaining</text>
            }
            else
            {
                <text>You have no hours remaining</text>
            }
        </div>
    </div>

    @if (TempData["SuccessMessage"] != null)
    {
        <div class="alert" style="background-color:#c8f0c8;">@TempData["SuccessMessage"]</div>
    }
    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert" style="background-color:#f0c8c8;">@TempData["ErrorMessage"]</div>
    }

    <div class="buy-title">Buy Hours</div>
    <div class="subtitle">Purchase additional hours to continue using Houra.</div>

    <div class="plans">
        @if (Model != null && Model.Any())
        {
            foreach (var package in Model)
            {
                <div class="plan">
                    <h3>@package.PackageName</h3>
                    <p>@package.HoursCount hours</p>
                    <p>$@package.Price</p>
                    <form asp-controller="TimeBank" asp-action="ConfirmPurchase" method="post">
                        <input type="hidden" name="packageId" value="@package.PackageId" />
                        <input type="hidden" name="pricePaid" value="@package.Price" />
                        <button type="submit">Purchase</button>
                    </form>
                </div>
            }
        }
        else
        {
            <p>No packages available right now.</p>
        }
    </div>
</body>
</html>
